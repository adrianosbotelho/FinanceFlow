{
  "name": "financeflow-macos",
  "version": "0.1.0",
  "description": "FinanceFlow desktop app for macOS",
  "author": "Adriano Botelho",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "node dev.js",
    "build": "node build-standalone.js && electron-builder --mac -c electron-builder.json",
    "pack": "node build-standalone.js && electron-builder --mac dir -c electron-builder.json"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
